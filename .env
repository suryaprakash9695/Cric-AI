# CricketVerse Environment Variables
# ⚠️ Never commit this file to version control

# ─── Server Configuration ─────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Cricket API (cricketdata.org / cricapi.com) ──────
CRICKET_API_KEY=your_cricket_api_key_here
CRICKET_API_BASE_URL=https://api.cricapi.com/v1

# ─── News API (newsapi.org — 100 req/day free) ────────
NEWS_API_KEY=your_news_api_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2

# ─── TheSportsDB (free tier key = 3) ─────────────────
SPORTS_DB_API_KEY=3
SPORTS_DB_BASE_URL=https://www.thesportsdb.com/api/v1/json

# ─── Cache TTL (in seconds) ───────────────────────────
CACHE_TTL_LIVE=30
CACHE_TTL_NEWS=300
CACHE_TTL_STATS=3600
